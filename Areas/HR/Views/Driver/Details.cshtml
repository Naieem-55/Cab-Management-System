@model Driver

@{
    ViewData["Title"] = "Driver Details";
}

<div class="container-fluid">
    <h1 class="mb-4">Driver Details</h1>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Employee Information</h5>
        </div>
        <div class="card-body">
            <div class="d-flex align-items-center gap-3 mb-3">
                @if (!string.IsNullOrEmpty(Model.Employee.ProfilePhotoPath))
                {
                    <img src="@Model.Employee.ProfilePhotoPath" alt="@Model.Employee.Name"
                         class="rounded-circle border" style="width: 64px; height: 64px; object-fit: cover;" />
                }
                else
                {
                    <i class="bi bi-person-circle text-secondary" style="font-size: 64px;"></i>
                }
                <div>
                    <div class="fw-bold fs-5">@Model.Employee.Name</div>
                    <div class="text-muted">@Model.Employee.Position</div>
                </div>
            </div>
            <dl class="row">
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Employee.Email</dd>

                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@Model.Employee.Phone</dd>
            </dl>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Driver Information</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">License Number</dt>
                <dd class="col-sm-9">@Model.LicenseNumber</dd>

                <dt class="col-sm-3">License Expiry</dt>
                <dd class="col-sm-9">
                    @if (Model.LicenseExpiry < DateTime.Today)
                    {
                        <span class="text-danger fw-bold">@Model.LicenseExpiry.ToString("MMM dd, yyyy") (Expired)</span>
                    }
                    else
                    {
                        @Model.LicenseExpiry.ToString("MMM dd, yyyy")
                    }
                </dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @switch (Model.Status)
                    {
                        case DriverStatus.Available:
                            <span class="badge bg-success">Available</span>
                            break;
                        case DriverStatus.OnTrip:
                            <span class="badge bg-warning">On Trip</span>
                            break;
                        case DriverStatus.OffDuty:
                            <span class="badge bg-secondary">Off Duty</span>
                            break;
                        case DriverStatus.Suspended:
                            <span class="badge bg-danger">Suspended</span>
                            break;
                    }
                </dd>
            </dl>
        </div>
    </div>

    @{
        var avgRating = (double)(ViewBag.AverageRating ?? 0d);
        var ratingCount = (int)(ViewBag.RatingCount ?? 0);
        var recentRatings = ViewBag.RecentRatings as List<CabManagementSystem.Models.DriverRating>
            ?? new List<CabManagementSystem.Models.DriverRating>();
    }
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-star-fill text-warning"></i> Customer Rating</h5>
            <a asp-action="Performance" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-graph-up"></i> Full Performance Report
            </a>
        </div>
        <div class="card-body">
            @if (ratingCount == 0)
            {
                <p class="text-muted text-center mb-0">
                    <i class="bi bi-star"></i> No ratings yet. Ratings appear after customers rate completed trips.
                </p>
            }
            else
            {
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="display-5 fw-bold text-warning">@avgRating.ToString("0.0")</div>
                    <div>
                        <div class="fs-4">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= Math.Round(avgRating) ? "bi-star-fill" : "bi-star") text-warning"></i>
                            }
                        </div>
                        <small class="text-muted">Based on @ratingCount rating@(ratingCount == 1 ? "" : "s")</small>
                    </div>
                </div>

                <h6 class="text-muted">Recent Reviews</h6>
                <ul class="list-group list-group-flush">
                    @foreach (var r in recentRatings)
                    {
                        <li class="list-group-item px-0">
                            <div class="d-flex justify-content-between">
                                <span class="fw-semibold">@r.CustomerName</span>
                                <span class="text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= r.Rating ? "bi-star-fill" : "bi-star")"></i>
                                    }
                                </span>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(r.Comment))
                            {
                                <small class="text-muted"><em>"@r.Comment"</em></small>
                            }
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>
