@model IEnumerable<Vehicle>

@{
    ViewData["Title"] = "Vehicles";
    var total = Model.Count();
    var available = Model.Count(v => v.Status == VehicleStatus.Available);
    var onTrip = Model.Count(v => v.Status == VehicleStatus.OnTrip);
    var inMaint = Model.Count(v => v.Status == VehicleStatus.InMaintenance);

    var statusBadgeMap = new Dictionary<VehicleStatus, string> {
        { VehicleStatus.Available, "pro-badge-green" },
        { VehicleStatus.OnTrip, "pro-badge-yellow" },
        { VehicleStatus.InMaintenance, "pro-badge-blue" },
        { VehicleStatus.Retired, "pro-badge-gray" },
    };

    var fuelIconMap = new Dictionary<FuelType, (string icon, string bg, string color)> {
        { FuelType.Petrol, ("bi-fuel-pump", "#fef3c7", "#d97706") },
        { FuelType.Diesel, ("bi-fuel-pump-fill", "#e0e7ff", "#4f46e5") },
        { FuelType.Electric, ("bi-lightning-charge", "#dcfce7", "#16a34a") },
        { FuelType.Hybrid, ("bi-recycle", "#ccfbf1", "#0d9488") },
        { FuelType.CNG, ("bi-wind", "#dbeafe", "#2563eb") },
    };
}

<!-- Header -->
<div class="pro-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2><i class="bi bi-truck me-2"></i>Vehicles</h2>
            <p>Manage fleet vehicles, status, and maintenance</p>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="pro-stat"><span class="dot" style="background:#22c55e;"></span> @available Available</span>
            <span class="pro-stat"><span class="dot" style="background:#f59e0b;"></span> @onTrip On Trip</span>
            <span class="pro-stat"><span class="dot" style="background:#3b82f6;"></span> @inMaint Maintenance</span>
            <a asp-action="Export" class="btn btn-outline-light btn-sm px-3">
                <i class="bi bi-download me-1"></i> Export
            </a>
            <a asp-action="Create" class="btn btn-light btn-sm px-3">
                <i class="bi bi-plus-lg me-1"></i> Add Vehicle
            </a>
        </div>
    </div>
</div>

<!-- Search & Filter -->
<div class="pro-search">
    <div class="p-3">
        <form asp-action="Index" method="get">
            <div class="row g-2 align-items-end">
                <div class="col-md-5">
                    <div class="position-relative">
                        <i class="bi bi-search search-icon"></i>
                        <input type="text" name="searchTerm" class="form-control has-icon" placeholder="Search by registration, make, or model..." value="@ViewBag.SearchTerm" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select">
                        <option value="">All Statuses</option>
                        @foreach (var s in Enum.GetValues<VehicleStatus>())
                        {
                            <option value="@s" selected="@(ViewData["SelectedStatus"] is VehicleStatus vs && vs == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="fuelType" class="form-select">
                        <option value="">All Fuel Types</option>
                        @foreach (var ft in Enum.GetValues<FuelType>())
                        {
                            <option value="@ft" selected="@(ViewData["SelectedFuelType"] is FuelType vft && vft == ft)">@ft</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-dark flex-grow-1" style="border-radius:8px;height:42px;">Filter</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Any())
{
    <div class="pro-card">
        <div class="table-responsive">
            <table class="table pro-table">
                <thead>
                    <tr>
                        <th>Vehicle</th>
                        <th>Year</th>
                        <th>Fuel Type</th>
                        <th>Status</th>
                        <th>Mileage</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var vehicle in Model)
                    {
                        var badgeCls = statusBadgeMap.ContainsKey(vehicle.Status) ? statusBadgeMap[vehicle.Status] : "pro-badge-gray";
                        var (fIcon, fBg, fColor) = fuelIconMap.ContainsKey(vehicle.FuelType) ? fuelIconMap[vehicle.FuelType] : ("bi-fuel-pump", "#f1f5f9", "#64748b");
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="pro-icon" style="background:@fBg;color:@fColor;">
                                        <i class="bi @fIcon"></i>
                                    </span>
                                    <div>
                                        <div class="fw-medium">@vehicle.Make @vehicle.Model</div>
                                        <div class="text-muted" style="font-size:0.75rem;">@vehicle.RegistrationNumber</div>
                                    </div>
                                </div>
                            </td>
                            <td>@vehicle.Year</td>
                            <td>@vehicle.FuelType</td>
                            <td><span class="pro-badge @badgeCls"><span class="bdot"></span> @vehicle.Status</span></td>
                            <td>@vehicle.Mileage.ToString("N0") km</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@vehicle.Id" class="pro-action" title="Details"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@vehicle.Id" class="pro-action" title="Edit"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@vehicle.Id" class="pro-action pro-action-danger" title="Delete"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="_PaginationPartial" />
}
else
{
    <div class="pro-card">
        <div class="pro-empty">
            <i class="bi bi-truck d-block mb-2"></i>
            <p>No vehicles found</p>
            <a asp-action="Create" class="btn btn-dark btn-sm px-3">
                <i class="bi bi-plus-lg me-1"></i> Add Vehicle
            </a>
        </div>
    </div>
}
