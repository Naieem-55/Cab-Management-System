@model IEnumerable<CabManagementSystem.Models.Route>

@{
    ViewData["Title"] = "Routes";
    var total = Model.Count();
}

<!-- Header -->
<div class="pro-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2><i class="bi bi-signpost-2 me-2"></i>Routes</h2>
            <p>Manage travel routes, distances, and pricing</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="pro-stat"><i class="bi bi-signpost-2"></i> @total Routes</span>
            <a asp-action="Create" class="btn btn-light btn-sm px-3">
                <i class="bi bi-plus-lg me-1"></i> Add Route
            </a>
        </div>
    </div>
</div>

<!-- Search -->
<div class="pro-search">
    <div class="p-3">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <div class="flex-grow-1 position-relative">
                <i class="bi bi-search search-icon"></i>
                <input type="text" name="searchTerm" class="form-control has-icon" placeholder="Search by origin or destination..." value="@ViewBag.SearchTerm" />
            </div>
            <button type="submit" class="btn btn-dark px-4" style="border-radius:8px;height:42px;">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary px-3" style="border-radius:8px;height:42px;line-height:30px;">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
    </div>
</div>

@if (Model.Any())
{
    <div class="pro-card">
        <div class="table-responsive">
            <table class="table pro-table">
                <thead>
                    <tr>
                        <th>Route</th>
                        <th>Distance</th>
                        <th>Est. Time</th>
                        <th>Base Cost</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var route in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="pro-icon" style="background:#ccfbf1;color:#0d9488;">
                                        <i class="bi bi-arrow-right"></i>
                                    </span>
                                    <div>
                                        <div class="fw-medium">@route.Origin</div>
                                        <div class="text-muted" style="font-size:0.75rem;">to @route.Destination</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="fw-medium">@route.Distance.ToString("N1")</span>
                                <span class="text-muted" style="font-size:0.75rem;">km</span>
                            </td>
                            <td>
                                <span class="fw-medium">@route.EstimatedTimeHours.ToString("N1")</span>
                                <span class="text-muted" style="font-size:0.75rem;">hrs</span>
                            </td>
                            <td class="fw-semibold">@route.BaseCost.ToString("C")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@route.Id" class="pro-action" title="Details"><i class="bi bi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@route.Id" class="pro-action" title="Edit"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@route.Id" class="pro-action pro-action-danger" title="Delete"><i class="bi bi-trash"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="_PaginationPartial" />
}
else
{
    <div class="pro-card">
        <div class="pro-empty">
            <i class="bi bi-signpost-2 d-block mb-2"></i>
            <p>No routes found</p>
            <a asp-action="Create" class="btn btn-dark btn-sm px-3">
                <i class="bi bi-plus-lg me-1"></i> Add Route
            </a>
        </div>
    </div>
}
