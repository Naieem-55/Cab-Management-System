@using CabManagementSystem.Models.Enums
@model IEnumerable<UserViewModel>

@{
    ViewData["Title"] = "User Management";
    var userCount = Model.Count();
    var adminCount = Model.Count(u => u.Role == nameof(UserRole.Admin));
    var roleColorMap = new Dictionary<string, (string cls, string icon)> {
        { nameof(UserRole.Admin), ("pro-badge-red", "bi-shield-lock") },
        { nameof(UserRole.FinanceManager), ("pro-badge-green", "bi-cash-stack") },
        { nameof(UserRole.HRManager), ("pro-badge-blue", "bi-people") },
        { nameof(UserRole.TravelManager), ("pro-badge-purple", "bi-geo-alt") },
        { nameof(UserRole.Customer), ("pro-badge-cyan", "bi-person-heart") },
    };
}

<!-- Header -->
<div class="pro-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2><i class="bi bi-people-fill me-2"></i>User Management</h2>
            <p>Manage system users, roles, and permissions</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="pro-stat"><i class="bi bi-people"></i> @userCount Users</span>
            <a asp-action="Create" class="btn btn-light btn-sm px-3">
                <i class="bi bi-plus-lg me-1"></i> Create User
            </a>
        </div>
    </div>
</div>

<!-- Search -->
<div class="pro-search">
    <div class="p-3">
        <form asp-action="Index" method="get" class="d-flex gap-2">
            <div class="flex-grow-1 position-relative">
                <i class="bi bi-search search-icon"></i>
                <input type="text" name="searchTerm" class="form-control has-icon" placeholder="Search by name or email..." value="@ViewBag.SearchTerm" />
            </div>
            <button type="submit" class="btn btn-dark px-4" style="border-radius:8px;height:42px;">Search</button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary px-3" style="border-radius:8px;height:42px;line-height:30px;">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
    </div>
</div>

@if (Model.Any())
{
    <div class="pro-card">
        <div class="table-responsive">
            <table class="table pro-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var (badgeCls, roleIcon) = roleColorMap.ContainsKey(user.Role)
                            ? roleColorMap[user.Role] : ("pro-badge-gray", "bi-person");
                        var initials = string.Join("", (user.FullName ?? "U").Split(' ').Take(2).Select(n => n[0]));
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="pro-avatar fw-semibold" style="font-size:0.7rem;">@initials</div>
                                    <span class="fw-medium">@user.FullName</span>
                                </div>
                            </td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                <span class="pro-badge @badgeCls">
                                    <span class="bdot"></span> @user.Role
                                </span>
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@user.Id" class="pro-action" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@user.Id" class="pro-action" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@user.Id" class="pro-action pro-action-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <partial name="_PaginationPartial" />
}
else
{
    <div class="pro-card">
        <div class="pro-empty">
            <i class="bi bi-people d-block mb-2"></i>
            <p>No users found</p>
            <a asp-action="Create" class="btn btn-dark btn-sm px-3">
                <i class="bi bi-plus-lg me-1"></i> Create User
            </a>
        </div>
    </div>
}
