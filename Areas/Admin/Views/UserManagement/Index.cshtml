@using CabManagementSystem.Models.Enums
@model IEnumerable<UserViewModel>

@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>User Management</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Create User
        </a>
    </div>

    @if (TempData["StatusMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["StatusMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search Form -->
    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="input-group">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Search by name or email..." value="@ViewBag.SearchTerm" />
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-search me-1"></i> Search
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i> Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Any())
    {
        <!-- Users Table -->
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>@user.FullName</td>
                                    <td>@user.Email</td>
                                    <td>
                                        @switch (user.Role)
                                        {
                                            case nameof(UserRole.Admin):
                                                <span class="badge bg-danger">@user.Role</span>
                                                break;
                                            case nameof(UserRole.FinanceManager):
                                                <span class="badge bg-success">@user.Role</span>
                                                break;
                                            case nameof(UserRole.HRManager):
                                                <span class="badge bg-info">@user.Role</span>
                                                break;
                                            case nameof(UserRole.TravelManager):
                                                <span class="badge bg-warning">@user.Role</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@user.Role</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info me-1">
                                            <i class="bi bi-eye"></i> Details
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning me-1">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <partial name="_PaginationPartial" />
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-shield-lock text-muted" style="font-size: 3rem;"></i>
            <p class="text-muted mt-2 mb-3">No users found.</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add User
            </a>
        </div>
    }
</div>
