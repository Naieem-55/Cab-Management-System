@model Trip

@{
    ViewData["Title"] = "Trip Details";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-geo-alt"></i> Trip Details</h1>
        <div id="actionButtons">
            @if (Model.Status == TripStatus.Pending || Model.Status == TripStatus.Confirmed)
            {
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline" id="cancelForm"
                      onsubmit="return confirm('Are you sure you want to cancel this trip?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger me-2">
                        <i class="bi bi-x-circle"></i> Cancel Trip
                    </button>
                </form>
            }
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to My Trips
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Trip #@Model.Id</h5>
                </div>
                <div class="card-body">
                    <h6 class="text-muted mb-3">Route Information</h6>
                    <dl class="row">
                        <dt class="col-sm-4">Origin</dt>
                        <dd class="col-sm-8">@Model.Route?.Origin</dd>

                        <dt class="col-sm-4">Destination</dt>
                        <dd class="col-sm-8">@Model.Route?.Destination</dd>

                        <dt class="col-sm-4">Distance</dt>
                        <dd class="col-sm-8">@Model.Route?.Distance km</dd>
                    </dl>

                    <hr />

                    <h6 class="text-muted mb-3">Trip Details</h6>
                    <dl class="row">
                        <dt class="col-sm-4">Booking Date</dt>
                        <dd class="col-sm-8">@Model.BookingDate.ToString("MMM dd, yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Trip Date</dt>
                        <dd class="col-sm-8">@Model.TripDate.ToString("MMM dd, yyyy HH:mm")</dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8" id="statusBadge">
                            @switch (Model.Status)
                            {
                                case TripStatus.Pending:
                                    <span class="badge bg-warning text-dark">Pending</span>
                                    break;
                                case TripStatus.Confirmed:
                                    <span class="badge bg-info">Confirmed</span>
                                    break;
                                case TripStatus.InProgress:
                                    <span class="badge bg-primary">In Progress</span>
                                    break;
                                case TripStatus.Completed:
                                    <span class="badge bg-success">Completed</span>
                                    break;
                                case TripStatus.Cancelled:
                                    <span class="badge bg-danger">Cancelled</span>
                                    break;
                            }
                        </dd>

                        <dt class="col-sm-4">Cost</dt>
                        <dd class="col-sm-8"><strong>@Model.Cost.ToString("C")</strong></dd>
                    </dl>

                    <hr />

                    <h6 class="text-muted mb-3">Assignment</h6>
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Driver</dt>
                        <dd class="col-sm-8">@Model.Driver?.Employee?.Name</dd>

                        <dt class="col-sm-4">Vehicle</dt>
                        <dd class="col-sm-8">@Model.Vehicle?.RegistrationNumber (@Model.Vehicle?.Make @Model.Vehicle?.Model)</dd>
                    </dl>
                </div>
            </div>

            @if (Model.Billing != null)
            {
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="bi bi-receipt"></i> Payment Information</h5>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Amount</dt>
                            <dd class="col-sm-8">@Model.Billing.Amount.ToString("C")</dd>

                            <dt class="col-sm-4">Payment Method</dt>
                            <dd class="col-sm-8">@Model.Billing.PaymentMethod</dd>

                            <dt class="col-sm-4">Payment Status</dt>
                            <dd class="col-sm-8">
                                @switch (Model.Billing.Status)
                                {
                                    case PaymentStatus.Pending:
                                        <span class="badge bg-warning text-dark">Pending</span>
                                        break;
                                    case PaymentStatus.Completed:
                                        <span class="badge bg-success">Completed</span>
                                        break;
                                    case PaymentStatus.Failed:
                                        <span class="badge bg-danger">Failed</span>
                                        break;
                                    case PaymentStatus.Refunded:
                                        <span class="badge bg-secondary">Refunded</span>
                                        break;
                                }
                            </dd>

                            <dt class="col-sm-4">Payment Date</dt>
                            <dd class="col-sm-8">@Model.Billing.PaymentDate.ToString("MMM dd, yyyy")</dd>
                        </dl>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-info-circle"></i> Trip Status</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-column gap-3" id="progressTracker">
                        <div class="d-flex align-items-center" id="step-pending">
                            <i class="bi bi-circle-fill @(Model.Status >= TripStatus.Pending ? "text-success" : "text-muted") me-2"></i>
                            <span>Booking Received</span>
                        </div>
                        <div class="d-flex align-items-center" id="step-confirmed">
                            <i class="bi bi-circle-fill @(Model.Status >= TripStatus.Confirmed ? "text-success" : "text-muted") me-2"></i>
                            <span>Confirmed</span>
                        </div>
                        <div class="d-flex align-items-center" id="step-inprogress">
                            <i class="bi bi-circle-fill @(Model.Status >= TripStatus.InProgress ? "text-success" : "text-muted") me-2"></i>
                            <span>In Progress</span>
                        </div>
                        <div class="d-flex align-items-center" id="step-completed">
                            <i class="bi bi-circle-fill @(Model.Status >= TripStatus.Completed ? "text-success" : "text-muted") me-2"></i>
                            <span>Completed</span>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.Status == TripStatus.Completed)
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-star"></i> Rating</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.DriverRating != null)
                        {
                            <div class="text-center">
                                <div class="mb-2">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= Model.DriverRating.Rating ? "bi-star-fill text-warning" : "bi-star text-muted") fs-4"></i>
                                    }
                                </div>
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Rated</span>
                                @if (!string.IsNullOrEmpty(Model.DriverRating.Comment))
                                {
                                    <p class="text-muted mt-2 mb-0"><em>"@Model.DriverRating.Comment"</em></p>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center">
                                <p class="text-muted mb-3">Share your experience with this trip</p>
                                <a asp-action="Rate" asp-route-id="@Model.Id" class="btn btn-warning">
                                    <i class="bi bi-star"></i> Rate This Trip
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@if (Model.Status != TripStatus.Completed && Model.Status != TripStatus.Cancelled)
{
    @section Scripts {
        <script>
            var connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/trip-tracking")
                .withAutomaticReconnect()
                .build();

            var statusMap = {
                0: { text: 'Pending', badge: 'bg-warning text-dark' },
                1: { text: 'Confirmed', badge: 'bg-info' },
                2: { text: 'In Progress', badge: 'bg-primary' },
                3: { text: 'Completed', badge: 'bg-success' },
                4: { text: 'Cancelled', badge: 'bg-danger' }
            };

            var stepIds = ['step-pending', 'step-confirmed', 'step-inprogress', 'step-completed'];

            connection.on("TripStatusUpdated", function (tripId, statusCode, statusText) {
                // Update status badge
                var badgeEl = document.getElementById('statusBadge');
                if (badgeEl && statusMap[statusCode]) {
                    badgeEl.innerHTML = '<span class="badge ' + statusMap[statusCode].badge + '">' + statusMap[statusCode].text + '</span>';
                }

                // Update progress tracker
                stepIds.forEach(function (id, index) {
                    var step = document.getElementById(id);
                    if (step) {
                        var icon = step.querySelector('i');
                        if (icon) {
                            icon.className = index <= statusCode
                                ? 'bi bi-circle-fill text-success me-2'
                                : 'bi bi-circle-fill text-muted me-2';
                        }
                    }
                });

                // Hide cancel button when no longer Pending/Confirmed
                if (statusCode >= 2) {
                    var cancelForm = document.getElementById('cancelForm');
                    if (cancelForm) cancelForm.remove();
                }

                // Reload page when completed to show rating card
                if (statusCode >= 3) {
                    setTimeout(function () { location.reload(); }, 2000);
                }

                // Show toast
                var container = document.getElementById('toastContainer');
                if (container) {
                    var toastHtml = '<div class="toast align-items-center text-bg-info border-0" role="alert">' +
                        '<div class="d-flex"><div class="toast-body"><i class="bi bi-broadcast me-2"></i>' +
                        'Trip status updated: <strong>' + statusText + '</strong></div>' +
                        '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>';
                    container.insertAdjacentHTML('beforeend', toastHtml);
                    new bootstrap.Toast(container.lastElementChild, { delay: 4000 }).show();
                }
            });

            connection.start().then(function () {
                connection.invoke("JoinTripGroup", @Model.Id);
            });
        </script>
    }
}
