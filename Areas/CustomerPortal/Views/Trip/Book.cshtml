@model CustomerBookTripViewModel

@{
    ViewData["Title"] = "Book a Trip";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-plus-circle"></i> Book a Trip</h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to My Trips
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-taxi-front"></i> Trip Booking Form</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Book" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="RouteId" class="form-label fw-bold"></label>
                            <select asp-for="RouteId" asp-items="Model.AvailableRoutes" class="form-select">
                                <option value="">-- Select a Route --</option>
                            </select>
                            <span asp-validation-for="RouteId" class="text-danger"></span>
                            <div class="form-text">Select your desired route. Price is based on the route's base cost.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TripDate" class="form-label fw-bold"></label>
                            <input asp-for="TripDate" class="form-control" type="datetime-local" />
                            <span asp-validation-for="TripDate" class="text-danger"></span>
                            <div class="form-text">Select your preferred date and time for the trip.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-bold"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"
                                      placeholder="Any special requirements or instructions..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PromoCode" class="form-label fw-bold">
                                <i class="bi bi-tag-fill text-success"></i> Promo Code
                            </label>
                            <div class="input-group">
                                <input asp-for="PromoCode" class="form-control text-uppercase"
                                       placeholder="Enter promo code (optional)" autocomplete="off" id="PromoCode" />
                                <button type="button" class="btn btn-outline-success" id="applyPromoBtn">
                                    <i class="bi bi-check2"></i> Apply
                                </button>
                            </div>
                            <span asp-validation-for="PromoCode" class="text-danger"></span>
                            <div id="promoStatus" class="form-text">Have a promo code? Enter it to get a discount on this trip.</div>
                        </div>

                        @if (Model.AvailablePoints > 0)
                        {
                            <div class="mb-4 p-3" style="background:#fef3c7; border:1px solid #f59e0b; border-radius:0.375rem;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <label asp-for="PointsToRedeem" class="form-label fw-bold mb-0">
                                        <i class="bi bi-award-fill" style="color:#d97706;"></i> Redeem Loyalty Points
                                    </label>
                                    <span class="badge" style="background:#d97706;">@Model.AvailablePoints available</span>
                                </div>
                                <div class="input-group">
                                    <input asp-for="PointsToRedeem" type="number" class="form-control"
                                           id="PointsToRedeem" min="0" max="@Model.AvailablePoints" step="100" />
                                    <span class="input-group-text">= <span id="discountPreview">৳0.00</span> discount</span>
                                </div>
                                <span asp-validation-for="PointsToRedeem" class="text-danger"></span>
                                <div class="form-text">100 points = ৳1 discount. Redemption cannot exceed trip cost.</div>
                            </div>
                        }

                        <div class="card mb-4 border-primary" id="fareCard">
                            <div class="card-header bg-light fw-bold">
                                <i class="bi bi-receipt"></i> Fare Estimate
                            </div>
                            <div class="card-body py-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span>Base fare</span>
                                    <span id="fareBase">—</span>
                                </div>
                                <div class="d-flex justify-content-between mb-1 text-success" id="farePromoRow" style="display:none !important;">
                                    <span><i class="bi bi-tag"></i> Promo discount</span>
                                    <span id="farePromo">-৳0.00</span>
                                </div>
                                <div class="d-flex justify-content-between mb-1 text-warning" id="fareLoyaltyRow" style="display:none !important;">
                                    <span><i class="bi bi-award"></i> Points discount</span>
                                    <span id="fareLoyalty">-৳0.00</span>
                                </div>
                                <hr class="my-2" />
                                <div class="d-flex justify-content-between fw-bold fs-5">
                                    <span>Estimated total</span>
                                    <span id="fareTotal" class="text-primary">—</span>
                                </div>
                            </div>
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i>
                            <strong>Note:</strong> A driver and vehicle will be automatically assigned to your trip.
                            Your trip will be in "Pending" status until confirmed by the travel manager.
                            Final total is confirmed at booking.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Book Trip
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var fares = @Html.Raw(Model.RouteFaresJson);
            var validateUrl = '@Url.Action("ValidatePromo")';

            var routeSel = document.getElementById('RouteId');
            var promoInput = document.getElementById('PromoCode');
            var applyBtn = document.getElementById('applyPromoBtn');
            var promoStatus = document.getElementById('promoStatus');
            var pointsInput = document.getElementById('PointsToRedeem');
            var pointsPreview = document.getElementById('discountPreview');

            var baseEl = document.getElementById('fareBase');
            var promoEl = document.getElementById('farePromo');
            var promoRow = document.getElementById('farePromoRow');
            var loyaltyEl = document.getElementById('fareLoyalty');
            var loyaltyRow = document.getElementById('fareLoyaltyRow');
            var totalEl = document.getElementById('fareTotal');

            var baseFare = 0, promoDiscount = 0, loyaltyDiscount = 0;

            function money(n) { return '৳' + (n || 0).toFixed(2); }

            function recompute() {
                if (!routeSel || !routeSel.value || !(routeSel.value in fares)) {
                    baseFare = 0;
                    baseEl.textContent = '—';
                    totalEl.textContent = '—';
                } else {
                    baseFare = Number(fares[routeSel.value]);
                    baseEl.textContent = money(baseFare);
                }

                // Loyalty discount capped at base minus promo
                var pts = pointsInput ? (parseInt(pointsInput.value) || 0) : 0;
                loyaltyDiscount = pts / 100;
                var maxLoyalty = Math.max(0, baseFare - promoDiscount);
                if (loyaltyDiscount > maxLoyalty) loyaltyDiscount = maxLoyalty;

                // Promo row
                if (promoDiscount > 0) {
                    promoRow.style.setProperty('display', 'flex', 'important');
                    promoEl.textContent = '-' + money(promoDiscount);
                } else {
                    promoRow.style.setProperty('display', 'none', 'important');
                }

                // Loyalty row
                if (loyaltyDiscount > 0) {
                    loyaltyRow.style.setProperty('display', 'flex', 'important');
                    loyaltyEl.textContent = '-' + money(loyaltyDiscount);
                } else {
                    loyaltyRow.style.setProperty('display', 'none', 'important');
                }

                if (pointsPreview) pointsPreview.textContent = money(loyaltyDiscount);

                if (baseFare > 0) {
                    var total = Math.max(0, baseFare - promoDiscount - loyaltyDiscount);
                    totalEl.textContent = money(total);
                }
            }

            function resetPromo(msg, cls) {
                promoDiscount = 0;
                promoStatus.textContent = msg;
                promoStatus.className = 'form-text' + (cls ? ' ' + cls : '');
                recompute();
            }

            function applyPromo() {
                var code = (promoInput.value || '').trim();
                if (!code) { resetPromo('Enter a promo code to apply.', 'text-danger'); return; }
                if (!routeSel.value) { resetPromo('Select a route first.', 'text-danger'); return; }

                var token = document.querySelector('input[name="__RequestVerificationToken"]');
                var body = new URLSearchParams();
                body.append('code', code);
                body.append('routeId', routeSel.value);
                if (token) body.append('__RequestVerificationToken', token.value);

                applyBtn.disabled = true;
                promoStatus.textContent = 'Checking…';
                promoStatus.className = 'form-text text-muted';

                fetch(validateUrl, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' }, body: body })
                    .then(function (r) {
                        if (!r.ok) throw new Error('HTTP ' + r.status);
                        return r.json();
                    })
                    .then(function (d) {
                        applyBtn.disabled = false;
                        if (d.valid) {
                            promoDiscount = Number(d.discount) || 0;
                            promoStatus.textContent = (d.message || 'Promo applied!') + ' (-' + money(promoDiscount) + ')';
                            promoStatus.className = 'form-text text-success fw-bold';
                        } else {
                            resetPromo(d.message || 'Invalid promo code.', 'text-danger');
                        }
                        recompute();
                    })
                    .catch(function (err) {
                        applyBtn.disabled = false;
                        console.error('Promo validation failed:', err);
                        resetPromo('Could not validate promo (' + err.message + '). Try again.', 'text-danger');
                    });
            }

            if (routeSel) routeSel.addEventListener('change', function () {
                if (promoDiscount > 0) resetPromo('Route changed — re-apply promo code.', 'text-warning');
                recompute();
            });
            if (applyBtn) applyBtn.addEventListener('click', applyPromo);
            if (promoInput) promoInput.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') { e.preventDefault(); applyPromo(); }
            });
            if (pointsInput) pointsInput.addEventListener('input', recompute);

            recompute();
        })();
    </script>
}
