@model CustomerBookTripViewModel

@{
    ViewData["Title"] = "Book a Trip";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-plus-circle"></i> Book a Trip</h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to My Trips
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-taxi-front"></i> Trip Booking Form</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Book" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="RouteId" class="form-label fw-bold"></label>
                            <select asp-for="RouteId" asp-items="Model.AvailableRoutes" class="form-select">
                                <option value="">-- Select a Route --</option>
                            </select>
                            <span asp-validation-for="RouteId" class="text-danger"></span>
                            <div class="form-text">Select your desired route. Price is based on the route's base cost.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TripDate" class="form-label fw-bold"></label>
                            <input asp-for="TripDate" class="form-control" type="datetime-local" />
                            <span asp-validation-for="TripDate" class="text-danger"></span>
                            <div class="form-text">Select your preferred date and time for the trip.</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-bold"></label>
                            <textarea asp-for="Notes" class="form-control" rows="3"
                                      placeholder="Any special requirements or instructions..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        @if (Model.AvailablePoints > 0)
                        {
                            <div class="mb-4 p-3" style="background:#fef3c7; border:1px solid #f59e0b; border-radius:0.375rem;">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <label asp-for="PointsToRedeem" class="form-label fw-bold mb-0">
                                        <i class="bi bi-award-fill" style="color:#d97706;"></i> Redeem Loyalty Points
                                    </label>
                                    <span class="badge" style="background:#d97706;">@Model.AvailablePoints available</span>
                                </div>
                                <div class="input-group">
                                    <input asp-for="PointsToRedeem" type="number" class="form-control"
                                           id="PointsToRedeem" min="0" max="@Model.AvailablePoints" step="100" />
                                    <span class="input-group-text">= <span id="discountPreview">$0.00</span> discount</span>
                                </div>
                                <span asp-validation-for="PointsToRedeem" class="text-danger"></span>
                                <div class="form-text">100 points = $1 discount. Redemption cannot exceed trip cost.</div>
                            </div>
                        }

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i>
                            <strong>Note:</strong> A driver and vehicle will be automatically assigned to your trip.
                            Your trip will be in "Pending" status until confirmed by the travel manager.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Book Trip
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var pointsInput = document.getElementById('PointsToRedeem');
            var preview = document.getElementById('discountPreview');
            if (!pointsInput || !preview) return;

            function updatePreview() {
                var pts = parseInt(pointsInput.value) || 0;
                var discount = pts / 100;
                preview.textContent = '$' + discount.toFixed(2);
            }
            pointsInput.addEventListener('input', updatePreview);
            updatePreview();
        })();
    </script>
}
