@model CustomerDashboardViewModel

@{
    ViewData["Title"] = "My Dashboard";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-speedometer2"></i> Welcome, @Model.CustomerName!</h1>
        <a asp-area="CustomerPortal" asp-controller="Trip" asp-action="Book" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Book a Trip
        </a>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="card border-primary h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="me-3">
                        <i class="bi bi-geo-alt fs-1 text-primary"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-muted">Total Trips</h6>
                        <h2 class="card-title mb-0">@Model.TotalTrips</h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card border-warning h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="me-3">
                        <i class="bi bi-clock-history fs-1 text-warning"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-muted">Active Trips</h6>
                        <h2 class="card-title mb-0">@Model.ActiveTrips</h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="card border-success h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="me-3">
                        <i class="bi bi-cash-coin fs-1 text-success"></i>
                    </div>
                    <div>
                        <h6 class="card-subtitle mb-1 text-muted">Total Spent</h6>
                        <h2 class="card-title mb-0">@Model.TotalSpent.ToString("C")</h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <a asp-area="CustomerPortal" asp-controller="Loyalty" asp-action="Index" class="text-decoration-none">
                <div class="card h-100" style="border-color:#f59e0b;">
                    <div class="card-body d-flex align-items-center">
                        <div class="me-3">
                            <i class="bi bi-award-fill fs-1" style="color:#d97706;"></i>
                        </div>
                        <div>
                            <h6 class="card-subtitle mb-1 text-muted">Loyalty Points</h6>
                            <h2 class="card-title mb-0" style="color:#d97706;">@Model.LoyaltyPoints</h2>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-graph-up"></i> My Trips Over Time</h5></div>
                <div class="card-body"><canvas id="myTripsChart" style="max-height:260px;"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-cash-coin"></i> My Spending Over Time</h5></div>
                <div class="card-body"><canvas id="mySpendChart" style="max-height:260px;"></canvas></div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-8">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recent Trips</h5>
                    <a asp-area="CustomerPortal" asp-controller="Trip" asp-action="Index" class="btn btn-sm btn-outline-primary">
                        View All
                    </a>
                </div>
                <div class="card-body">
                    @if (Model.RecentTrips.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Date</th>
                                        <th>Route</th>
                                        <th>Status</th>
                                        <th>Cost</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var trip in Model.RecentTrips)
                                    {
                                        <tr>
                                            <td>@trip.TripDate.ToString("MMM dd, yyyy")</td>
                                            <td>@trip.Route?.Origin → @trip.Route?.Destination</td>
                                            <td>
                                                @switch (trip.Status)
                                                {
                                                    case TripStatus.Pending:
                                                        <span class="badge bg-warning text-dark">Pending</span>
                                                        break;
                                                    case TripStatus.Confirmed:
                                                        <span class="badge bg-info">Confirmed</span>
                                                        break;
                                                    case TripStatus.InProgress:
                                                        <span class="badge bg-primary">In Progress</span>
                                                        break;
                                                    case TripStatus.Completed:
                                                        <span class="badge bg-success">Completed</span>
                                                        break;
                                                    case TripStatus.Cancelled:
                                                        <span class="badge bg-danger">Cancelled</span>
                                                        break;
                                                }
                                            </td>
                                            <td>@trip.Cost.ToString("C")</td>
                                            <td>
                                                <a asp-area="CustomerPortal" asp-controller="Trip" asp-action="Details"
                                                   asp-route-id="@trip.Id" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="bi bi-geo-alt text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-2">No trips yet. Book your first trip!</p>
                            <a asp-area="CustomerPortal" asp-controller="Trip" asp-action="Book" class="btn btn-primary">
                                <i class="bi bi-plus-circle"></i> Book a Trip
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-lightning"></i> Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-area="CustomerPortal" asp-controller="Trip" asp-action="Book" class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> Book New Trip
                        </a>
                        <a asp-area="CustomerPortal" asp-controller="Trip" asp-action="Index" class="btn btn-outline-primary">
                            <i class="bi bi-list-ul"></i> My Trips
                        </a>
                        <a asp-area="CustomerPortal" asp-controller="Invoice" asp-action="Index" class="btn btn-outline-success">
                            <i class="bi bi-receipt"></i> My Invoices
                        </a>
                        <a asp-area="CustomerPortal" asp-controller="Loyalty" asp-action="Index" class="btn btn-outline-warning">
                            <i class="bi bi-award-fill"></i> Loyalty Points
                        </a>
                        <a asp-area="CustomerPortal" asp-controller="Profile" asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-person"></i> My Profile
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var _theme = document.documentElement.getAttribute('data-theme') || 'light';
        Chart.defaults.color = _theme === 'dark' ? '#e4e6ea' : '#666';
        Chart.defaults.borderColor = _theme === 'dark' ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)';

        var monthLabels = @Html.Raw(Json.Serialize(Model.MonthlyLabels));

        var tripsCtx = document.getElementById('myTripsChart').getContext('2d');
        var tripsGradient = tripsCtx.createLinearGradient(0, 0, 0, 260);
        tripsGradient.addColorStop(0, 'rgba(13,110,253,0.35)'); tripsGradient.addColorStop(1, 'rgba(13,110,253,0.0)');
        new Chart(tripsCtx, {
            type: 'line',
            data: { labels: monthLabels, datasets: [{ label: 'Trips', data: @Html.Raw(Json.Serialize(Model.MonthlyTripCounts)), borderColor: '#0d6efd', backgroundColor: tripsGradient, borderWidth: 2, fill: true, tension: 0.35, pointBackgroundColor: '#0d6efd', pointRadius: 4, pointHoverRadius: 6 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(ctx) { return ' '+ctx.raw+' trips'; } } } }, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
        });

        var spendCtx = document.getElementById('mySpendChart').getContext('2d');
        var spendGradient = spendCtx.createLinearGradient(0, 0, 0, 260);
        spendGradient.addColorStop(0, 'rgba(25,135,84,0.35)'); spendGradient.addColorStop(1, 'rgba(25,135,84,0.0)');
        new Chart(spendCtx, {
            type: 'line',
            data: { labels: monthLabels, datasets: [{ label: 'Spent', data: @Html.Raw(Json.Serialize(Model.MonthlySpendData)), borderColor: '#198754', backgroundColor: spendGradient, borderWidth: 2, fill: true, tension: 0.35, pointBackgroundColor: '#198754', pointRadius: 4, pointHoverRadius: 6 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: { callbacks: { label: function(ctx) { return ' ৳'+ctx.raw.toLocaleString(); } } } }, scales: { y: { beginAtZero: true, ticks: { callback: function(v) { return '৳'+v.toLocaleString(); } } } } }
        });
    </script>
}
