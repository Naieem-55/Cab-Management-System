@model Trip

@{
    ViewData["Title"] = "Trip Details";
}

<div class="container">
    <h2 class="mb-4">Trip Details</h2>

    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Trip #@Model.Id</h5>
        </div>
        <div class="card-body">
            <!-- Customer Information -->
            <h5 class="mt-2">Customer Information</h5>
            <dl class="row">
                <dt class="col-sm-3">Customer Name</dt>
                <dd class="col-sm-9">@Model.CustomerName</dd>

                <dt class="col-sm-3">Customer Phone</dt>
                <dd class="col-sm-9">@Model.CustomerPhone</dd>

                <dt class="col-sm-3">Customer Email</dt>
                <dd class="col-sm-9">@(Model.CustomerEmail ?? "N/A")</dd>
            </dl>

            <hr />

            <!-- Trip Information -->
            <h5 class="mt-3">Trip Information</h5>
            <dl class="row">
                <dt class="col-sm-3">Booking Date</dt>
                <dd class="col-sm-9">@Model.BookingDate.ToString("MMM dd, yyyy HH:mm")</dd>

                <dt class="col-sm-3">Trip Date</dt>
                <dd class="col-sm-9">@Model.TripDate.ToString("MMM dd, yyyy HH:mm")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @switch (Model.Status)
                    {
                        case TripStatus.Pending:
                            <span class="badge bg-warning text-dark">Pending</span>
                            break;
                        case TripStatus.Confirmed:
                            <span class="badge bg-info">Confirmed</span>
                            break;
                        case TripStatus.InProgress:
                            <span class="badge bg-primary">In Progress</span>
                            break;
                        case TripStatus.Completed:
                            <span class="badge bg-success">Completed</span>
                            break;
                        case TripStatus.Cancelled:
                            <span class="badge bg-danger">Cancelled</span>
                            break;
                    }
                </dd>

                <dt class="col-sm-3">Cost</dt>
                <dd class="col-sm-9">@Model.Cost.ToString("C")</dd>
            </dl>

            <hr />

            <!-- Assignment -->
            <h5 class="mt-3">Assignment</h5>
            <dl class="row">
                <dt class="col-sm-3">Driver</dt>
                <dd class="col-sm-9">@Model.Driver?.Employee?.Name</dd>

                <dt class="col-sm-3">Vehicle</dt>
                <dd class="col-sm-9">@Model.Vehicle?.RegistrationNumber</dd>
            </dl>

            <hr />

            <!-- Route -->
            <h5 class="mt-3">Route</h5>
            <dl class="row">
                <dt class="col-sm-3">Origin</dt>
                <dd class="col-sm-9">@Model.Route?.Origin</dd>

                <dt class="col-sm-3">Destination</dt>
                <dd class="col-sm-9">@Model.Route?.Destination</dd>

                <dt class="col-sm-3">Distance</dt>
                <dd class="col-sm-9">@Model.Route?.Distance km</dd>

                <dt class="col-sm-3">Base Cost</dt>
                <dd class="col-sm-9">@Model.Route?.BaseCost.ToString("C")</dd>
            </dl>

            @if (Model.Billing != null)
            {
                <hr />

                <!-- Billing -->
                <h5 class="mt-3">Billing</h5>
                <dl class="row">
                    <dt class="col-sm-3">Amount</dt>
                    <dd class="col-sm-9">@Model.Billing.Amount.ToString("C")</dd>

                    <dt class="col-sm-3">Payment Method</dt>
                    <dd class="col-sm-9">@Model.Billing.PaymentMethod</dd>

                    <dt class="col-sm-3">Payment Status</dt>
                    <dd class="col-sm-9">
                        @switch (Model.Billing.Status)
                        {
                            case PaymentStatus.Pending:
                                <span class="badge bg-warning text-dark">Pending</span>
                                break;
                            case PaymentStatus.Completed:
                                <span class="badge bg-success">Completed</span>
                                break;
                            case PaymentStatus.Failed:
                                <span class="badge bg-danger">Failed</span>
                                break;
                            case PaymentStatus.Refunded:
                                <span class="badge bg-secondary">Refunded</span>
                                break;
                        }
                    </dd>

                    <dt class="col-sm-3">Payment Date</dt>
                    <dd class="col-sm-9">@Model.Billing.PaymentDate.ToString("MMM dd, yyyy")</dd>
                </dl>
            }
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        @if (Model.Status == TripStatus.Pending)
        {
            <button id="simulateBtn" class="btn btn-info" onclick="startSimulation(@Model.Id)">
                <i class="bi bi-play-circle"></i> Simulate Trip
            </button>
        }
        @if (Model.Status == TripStatus.Completed && Model.DriverRating == null)
        {
            <a asp-action="Rate" asp-route-id="@Model.Id" class="btn btn-warning">
                <i class="bi bi-star"></i> Rate This Trip
            </a>
        }
        else if (Model.DriverRating != null)
        {
            <span class="btn btn-success disabled">
                <i class="bi bi-check-circle"></i> Rated (@Model.DriverRating.Rating/5)
            </span>
        }
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <!-- Simulation Progress -->
    <div id="simulationProgress" class="mt-3 d-none">
        <div class="card border-info">
            <div class="card-body">
                <h6><i class="bi bi-activity"></i> Trip Simulation Running</h6>
                <div class="d-flex align-items-center gap-3 mt-2">
                    <div class="d-flex align-items-center" id="simStep1">
                        <i class="bi bi-circle text-muted me-1"></i> Confirmed
                    </div>
                    <i class="bi bi-arrow-right text-muted"></i>
                    <div class="d-flex align-items-center" id="simStep2">
                        <i class="bi bi-circle text-muted me-1"></i> In Progress
                    </div>
                    <i class="bi bi-arrow-right text-muted"></i>
                    <div class="d-flex align-items-center" id="simStep3">
                        <i class="bi bi-circle text-muted me-1"></i> Completed
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/trip-tracking")
            .withAutomaticReconnect()
            .build();

        connection.on("TripStatusUpdated", function (tripId, statusCode, statusText) {
            // Update simulation progress steps
            if (statusCode >= 1) document.getElementById('simStep1').innerHTML = '<i class="bi bi-check-circle-fill text-success me-1"></i> Confirmed';
            if (statusCode >= 2) document.getElementById('simStep2').innerHTML = '<i class="bi bi-check-circle-fill text-success me-1"></i> In Progress';
            if (statusCode >= 3) {
                document.getElementById('simStep3').innerHTML = '<i class="bi bi-check-circle-fill text-success me-1"></i> Completed';
                setTimeout(function () { location.reload(); }, 1500);
            }

            // Show toast
            showToast(statusText, 'Trip #' + tripId + ' is now ' + statusText);
        });

        connection.start().then(function () {
            connection.invoke("JoinTripGroup", @Model.Id);
        });

        function startSimulation(tripId) {
            var btn = document.getElementById('simulateBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Starting...';

            fetch('@Url.Action("StartSimulation")?id=' + tripId, { method: 'POST' })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.success) {
                        btn.innerHTML = '<i class="bi bi-check-circle"></i> Simulation Running';
                        document.getElementById('simulationProgress').classList.remove('d-none');
                    } else {
                        btn.disabled = false;
                        btn.innerHTML = '<i class="bi bi-play-circle"></i> Simulate Trip';
                        alert(data.message);
                    }
                });
        }

        function showToast(title, message) {
            var container = document.getElementById('toastContainer');
            if (!container) return;
            var toastHtml = '<div class="toast align-items-center text-bg-info border-0" role="alert">' +
                '<div class="d-flex"><div class="toast-body"><i class="bi bi-broadcast me-2"></i>' +
                message + '</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div></div>';
            container.insertAdjacentHTML('beforeend', toastHtml);
            var toastEl = container.lastElementChild;
            new bootstrap.Toast(toastEl, { delay: 4000 }).show();
        }
    </script>
}
