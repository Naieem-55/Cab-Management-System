@model CabManagementSystem.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-primary text-white text-center">
                <h4 class="mb-0"><i class="bi bi-person-circle"></i> My Profile</h4>
            </div>
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-person-circle text-muted" style="font-size: 4rem;"></i>
                </div>
                <table class="table">
                    <tr>
                        <th class="w-25">First Name</th>
                        <td>@Model.FirstName</td>
                    </tr>
                    <tr>
                        <th>Last Name</th>
                        <td>@Model.LastName</td>
                    </tr>
                    <tr>
                        <th>Email</th>
                        <td>@Model.Email</td>
                    </tr>
                    <tr>
                        <th>Role</th>
                        <td><span class="badge bg-info">@Model.Role</span></td>
                    </tr>
                </table>
                <div class="d-flex gap-2 justify-content-center mt-3">
                    <a asp-action="EditProfile" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Edit Profile
                    </a>
                    <a asp-action="ChangePassword" class="btn btn-outline-secondary">
                        <i class="bi bi-key"></i> Change Password
                    </a>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-1"><i class="bi bi-shield-lock"></i> Two-Factor Authentication</h6>
                        @if (Model.TwoFactorEnabled)
                        {
                            <span class="badge bg-success">Enabled</span>
                            <small class="text-muted d-block mt-1">A code is emailed to you at each login.</small>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Disabled</span>
                            <small class="text-muted d-block mt-1">Add an extra layer of security with email codes.</small>
                        }
                    </div>
                    @if (Model.TwoFactorEnabled)
                    {
                        <form asp-action="DisableTwoFactor" method="post">
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-shield-slash"></i> Disable
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="EnableTwoFactor" method="post">
                            <button type="submit" class="btn btn-outline-success btn-sm">
                                <i class="bi bi-shield-check"></i> Enable
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
