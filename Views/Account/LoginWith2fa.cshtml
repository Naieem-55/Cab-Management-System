@model LoginWith2faViewModel
@{
    ViewData["Title"] = "Two-Factor Verification";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-primary text-white text-center">
                <h4 class="mb-0"><i class="bi bi-shield-check"></i> Two-Factor Verification</h4>
            </div>
            <div class="card-body p-4">
                <p class="text-muted">A verification code was sent to your email. Enter it below to complete sign in.</p>
                <form asp-action="LoginWith2fa" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="RememberMe" />

                    <div class="mb-3">
                        <label asp-for="TwoFactorCode" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-key"></i></span>
                            <input asp-for="TwoFactorCode" class="form-control" autocomplete="off"
                                   inputmode="numeric" placeholder="Enter the code" />
                        </div>
                        <span asp-validation-for="TwoFactorCode" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="RememberMachine" class="form-check-input" />
                        <label asp-for="RememberMachine" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check2-circle"></i> Verify
                    </button>
                </form>

                <form asp-action="ResendTwoFactorCode" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="mt-3 text-center">
                    <input type="hidden" name="rememberMe" value="@Model.RememberMe.ToString()" />
                    <button type="submit" class="btn btn-link text-decoration-none">
                        <i class="bi bi-arrow-repeat"></i> Resend Code
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
